@startuml
title Sequence Diagram for Storage Load (Main Control Flow Only)

autonumber
hide footbox

participant ":InventoryDock" as InventoryDock
participant ":Storage" as Storage
participant ":Command" as Command
participant ":Inventory" as Inventory
participant ":UI" as UI

activate InventoryDock
InventoryDock -> Storage: load(inventory, ui)
activate Storage

Storage -> Storage: createFile()
activate Storage
Storage --> Storage
deactivate Storage

Storage -> Storage: readAllLines(dataFile)
activate Storage
Storage --> Storage
deactivate Storage

create ":AddItemCommandParser" as AddItemCommandParser
Storage -> AddItemCommandParser: AddItemCommandParser()
activate AddItemCommandParser
AddItemCommandParser --> Storage

loop for each line in storage file
    Storage -> Storage: parseStoredLine(line, addItemCommandParser)
    activate Storage
    Storage --> Storage
    deactivate Storage

    Storage -> Storage: extractCategory(line)
    activate Storage
    Storage --> Storage
    deactivate Storage

    alt category is valid
        Storage -> AddItemCommandParser: handleCategory(line)
        activate AddItemCommandParser
        AddItemCommandParser --> Storage: command
        deactivate AddItemCommandParser

        Storage -> Command: execute(inventory, null)
        activate Command
        Command -> Inventory: add loaded item
        activate Inventory
        Inventory --> Command
        deactivate Inventory
        Command --> Storage
        deactivate Command
    else else
        Storage -> UI: showSkippedLine(line, errorMessage)
        activate UI
        UI --> Storage
        deactivate UI
    end
end

Storage --> InventoryDock
deactivate Storage
deactivate InventoryDock

@enduml

