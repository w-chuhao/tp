@startuml
title Sequence Diagram for FindItemByQtyCommand (Inventory Scan and Quantity Matching)

autonumber
hide footbox

participant ":FindItemByQtyCommand" as FindItemByQtyCommand
participant ":Inventory" as Inventory
participant ":Category" as Category
participant ":Item" as Item

FindItemByQtyCommand -> Inventory: getCategories()
activate Inventory
Inventory --> FindItemByQtyCommand: categories
deactivate Inventory

loop for each category in categories
    FindItemByQtyCommand -> Category: getItems()
    activate Category
    Category --> FindItemByQtyCommand: items
    deactivate Category

    loop for each item in items
        FindItemByQtyCommand -> Item: getQuantity()
        activate Item
        Item --> FindItemByQtyCommand: quantity
        deactivate Item

        FindItemByQtyCommand -> FindItemByQtyCommand: quantity <= qtyInput
        activate FindItemByQtyCommand
        FindItemByQtyCommand --> FindItemByQtyCommand
        deactivate FindItemByQtyCommand
    end
end
@enduml

