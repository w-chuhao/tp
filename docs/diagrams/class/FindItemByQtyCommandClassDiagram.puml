@startuml
skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam packageStyle rectangle
hide empty members

title Class Diagram for FindItemByQtyCommand

package "seedu.inventorydock.command" {
  abstract class Command {
    +execute(inventory: Inventory, ui: UI)
    +isExit(): boolean
  }

  class FindItemByQtyCommand {
    -logger: Logger
    -qtyInput: int
    +FindItemByQtyCommand(qtyInput: int)
    +parseQtyInput(qtyInput: String): int
    +execute(inventory: Inventory, ui: UI)
  }
}

package "seedu.inventorydock.model" {
  class Inventory {
    -inventory: List
    +Inventory()
    +addCategory(category: Category)
    +getCategories(): List
    +getCategory(index: int): Category
    +getCategoryCount(): int
    +findCategoryByName(categoryName: String): Category
    +hasCategory(categoryName: String): boolean
  }

  class Category {
    -name: String
    -items: List
    +Category(name: String)
    +getName(): String
    +setName(name: String)
    +getItems(): List
    +addItem(item: Item)
    +getItem(index: int): Item
    +getItemCount(): int
    +isEmpty(): boolean
    +removeItem(index: int)
    +findItemByName(itemName: String): Item
  }

  class Item {
    -name: String
    -quantity: int
    -binLocation: String
    -expiryDate: String
    +Item(name: String, quantity: int, binLocation: String, expiryDate: String)
    +getName(): String
    +setName(name: String)
    +getQuantity(): int
    +setQuantity(quantity: int)
    +getBinLocation(): String
    +setBinLocation(binLocation: String)
    +getExpiryDate(): String
    +setExpiryDate(expiryDate: String)
    +toStorageString(categoryName: String): String
    +toString(): String
  }
}

package "seedu.inventorydock.ui" {
  class UI {
    +showDivider()
    +showMessage(message: String)
    +formatFoundItemsMessage(matchCount: int, searchDescription: String): String
    +formatNoItemsFoundMessage(searchDescription: String): String
    +formatFindResultsHeader(resultsDescription: String): String
    +showNumberedList(items: List)
  }
}

package "seedu.inventorydock.exception" {
  class DukeException
}

Command <|-- FindItemByQtyCommand
Inventory *-- "0..*" Category : contains
Category *-- "0..*" Item : contains
FindItemByQtyCommand ..> Inventory : reads
FindItemByQtyCommand ..> UI : displays via
FindItemByQtyCommand ..> DukeException
FindItemByQtyCommand ..> Item : filters by quantity
FindItemByQtyCommand ..> Category : traverses

note right of FindItemByQtyCommand
execute() traverses:
Inventory -> Category -> Item
and collects items where
item.getQuantity() <= qtyInput
end note

@enduml